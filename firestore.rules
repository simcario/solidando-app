rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return request.auth.uid == resource.data.createdBy;
    }

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users
    match /users/{userId} {
      // Own profile: full access
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin: read all profiles (UsersPage) and update role field
      allow read, update: if isAdmin();
    }

    // Forms
    match /forms/{formId} {
      // get singolo: published, proprietario o admin
      allow get: if resource.data.published == true || isOwner(resource) || isAdmin();
      // list query (getForms): solo utenti autenticati
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      // update/delete: proprietario o admin
      allow update, delete: if isOwner(resource) || isAdmin();
    }

    // Responses: chiunque può inviare, autenticati possono leggere
    match /responses/{responseId} {
      allow create: if true;
      allow read, delete: if isAuthenticated();
    }

    // Workspace settings — lettura pubblica (clientId PayPal serve al runtime pubblico del form)
    // il clientSecret non viene mai scritto lato client; write solo per autenticati
    match /workspace_settings/{workspaceId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Events — admin può gestire, utenti autenticati possono leggere quelli pubblicati
    match /events/{eventId} {
      allow get: if resource.data.status == 'published' || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Notifications — ogni utente legge/aggiorna solo le proprie; scrittura solo da Cloud Functions (admin SDK)
    match /notifications/{notifId} {
      // list query con where('uid','==',uid): Firestore non espone i filtri nelle rules,
      // quindi permettiamo list agli autenticati e lasciamo che la query lato client
      // sia già filtrata per uid. Il get/update/delete singolo verifica il campo uid nel doc.
      allow list: if request.auth != null;
      allow get, update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if false; // solo Cloud Functions via admin SDK
    }
  }
}
